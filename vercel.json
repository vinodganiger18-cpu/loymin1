{
  "version": 2,
  "builds": [
    {
      "src": "perkpay-frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/auth/(.*)", "dest": "/api/index.js" },
    { "src": "/health", "dest": "/api/index.js" },
    { "handle": "filesystem" },
    {
      "src": "/(.*\\.[a-zA-Z0-9]+)$",
      "dest": "/perkpay-frontend/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/perkpay-frontend/index.html"
    }
  ],
  "crons": [
    { "path": "/api/payments/expire", "schedule": "0 0 * * *" }
  ]
}
