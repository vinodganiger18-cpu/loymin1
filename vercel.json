{
  "version": 2,
  "builds": [
    {
      "src": "perkpay-frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*\\.[a-zA-Z0-9]+)$",
      "dest": "/perkpay-frontend/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/perkpay-frontend/index.html"
    }
  ]
}
