# ─── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Auth ────────────────────────────────────────────────────
# Must be a random string of at least 32 chars in production.
# Generate one: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-string
JWT_ISSUER=perkpay
JWT_AUDIENCE=perkpay-app

# ─── Razorpay ────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated allowlist of frontend origins.
# Leave empty in local dev (reflects any origin).
# In production set to your Vercel URL, e.g.:
# CORS_ORIGIN=https://loymin1-dusky.vercel.app
CORS_ORIGIN=

# ─── Cron ────────────────────────────────────────────────────
# Shared secret for the /api/payments/expire cron endpoint.
# Set in Vercel env vars so only the cron scheduler can call it.
CRON_SECRET=

# ─── Server ──────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
QR_EXPIRY_MINUTES=10
